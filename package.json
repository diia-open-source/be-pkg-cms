{
    "name": "@diia-inhouse/cms",
    "version": "2.1.0",
    "description": "Cms utils",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-cms.git",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "find-circulars": "madge --circular --extensions ts ./",
        "test": "vitest run",
        "test:watch": "vitest watch"
    },
    "dependencies": {
        "qs": "6.15.0"
    },
    "peerDependencies": {
        "@diia-inhouse/errors": ">=1.0.0",
        "@diia-inhouse/http": ">=2.4.3",
        "@diia-inhouse/types": ">=1.0.0"
    },
    "devDependencies": {
        "@commitlint/cli": "20.4.2",
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.16.0",
        "@diia-inhouse/errors": "1.17.0",
        "@diia-inhouse/eslint-config": "8.2.4",
        "@diia-inhouse/http": "4.0.0",
        "@diia-inhouse/test": "7.2.0",
        "@diia-inhouse/types": "11.3.0",
        "@types/node": "25.3.3",
        "@types/qs": "6.14.0",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "n": "10.2.0",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.5",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "eslintConfig": {
        "extends": "@diia-inhouse/eslint-config",
        "rules": {
            "@typescript-eslint/no-unnecessary-condition": [
                "off"
            ]
        },
        "overrides": [
            {
                "files": [
                    "*.ts"
                ],
                "parserOptions": {
                    "project": [
                        "./tsconfig.json",
                        "./tests/tsconfig.json"
                    ]
                }
            }
        ]
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
